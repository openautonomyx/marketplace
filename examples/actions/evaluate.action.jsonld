{
  "@context": [
    "https://schema.org",
    "https://schema.openautonomyx.com/action/v1"
  ],
  "@type": "Action",
  "identifier": "action.evaluate",
  "name": "Evaluate skill in context",
  "description": "Score a skill across the twelve evaluation dimensions, context-weighted.",
  "actionCapability": "evaluate",
  "modelAgnostic": true,
  "object": {
    "type": "object",
    "required": ["skill", "context"],
    "properties": {
      "skill": { "$ref": "Skill" },
      "context": { "$ref": "SkillContext" }
    }
  },
  "result": { "$ref": "SkillEvaluation" }
}
